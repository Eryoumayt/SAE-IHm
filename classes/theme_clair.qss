QMainWindow {
    background-color: #00689f;
}

QWidget#menuGauche {
    background-color: #16213e;
}

QWidget#conteneurCentre {
    background-color: #00689f;
}

QMenuBar {
    background-color: #16213e;
    color: white;
}

QMenuBar::item:selected {
    background-color: #002244;
}

QMenu {
    background-color: #16213e;
    color: white;
}

QMenu::item {
    padding: 4px 20px 4px 12px;
}

QMenu::item:selected {
    background-color: #002244;
}