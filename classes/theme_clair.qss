QMainWindow {
    background-color: #003366;
}

QMenuBar {
    background-color: #002244;
    color: white;
}

QMenuBar::item:selected {
    background-color: #001a33;
}

QMenu {
    background-color: #002244;
    color: white;
}

QMenu::item {
    padding: 4px 20px 4px 12px;
}

QMenu::item:selected {
    background-color: #001a33;
}